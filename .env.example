# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-your-key

# Mailgun (HTTP API used for the weekly digest — no email SDK)
MAILGUN_API_KEY=your-mailgun-private-api-key
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_API_BASE_URL=https://api.mailgun.net/v3
DIGEST_FROM_EMAIL=compass@yourdomain.com

# Shared secret required in the `x-digest-secret` header to call /api/digest/send
# (point your scheduler — e.g. a cron job or Supabase Edge Function schedule — at it)
DIGEST_CRON_SECRET=a-long-random-string

# App — used to build absolute links inside the weekly digest email
# (the Village post link and the "manage your settings" footer link)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Terac (REST API — used directly by src/lib/terac, also doubles as the
# .mcp.json x-api-key header)
TERAC_API_KEY=tk_your_api_key
TERAC_PROJECT_ID=your-terac-project-id

# Daily.co — hosts the in-app video call room (src/lib/daily). Private room
# + a room-scoped meeting token are created per request; no dashboard setup
# beyond generating an API key is required.
DAILY_API_KEY=your-daily-api-key

# Vapi — comforting voice agent the parent talks to in-browser while waiting
# for a Terac match. NEXT_PUBLIC_VAPI_ASSISTANT_ID is minted once by running
# `node scripts/create-vapi-assistant.mjs` (uses VAPI_API_KEY, a private key,
# server-side only) and pasting the printed id here. The public key and
# assistant id are both safe to expose client-side — only VAPI_API_KEY is
# secret.
VAPI_API_KEY=your-vapi-private-api-key
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your-vapi-public-key
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your-minted-assistant-id

# Browserbase (live specialist + benefits search via Stagehand)
# Get your API key and project ID at https://browserbase.com
BROWSERBASE_API_KEY=your-browserbase-api-key
BROWSERBASE_PROJECT_ID=your-browserbase-project-id
# The model gateway lets Stagehand call Anthropic models billed to your
# Browserbase account — no separate ANTHROPIC_API_KEY needed for this feature.
# Default: https://api.browserbase.com/v1/anthropic
# Leave unset to use the default gateway URL, or override if Browserbase changes it.
# BROWSERBASE_MODEL_GATEWAY_URL=https://api.browserbase.com/v1/anthropic
